-- ════════════════════════════════════════════════════════
--  SCROLLABLE WINDOW
-- ════════════════════════════════════════════════════════
local function scrollWindow(sg, w, h, title, subtitle, onClose)
    local dim = Instance.new("Frame")
    dim.Size = UDim2.new(1, 0, 1, 0)
    dim.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    dim.BackgroundTransparency = 0.45
    dim.Parent = sg

    local win = Instance.new("Frame")
    win.Size = UDim2.new(0, w, 0, h)
    win.Position = UDim2.new(0.5, -w/2, 0.5, -h/2)
    win.BackgroundColor3 = C.bg
    win.BackgroundTransparency = 1
    win.Parent = sg
    corner(win, 14)
    stroke(win, C.border, 1.5)

    TweenService:Create(win,
        TweenInfo.new(0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
        {BackgroundTransparency = 0}):Play()

    local hdr = Instance.new("Frame")
    hdr.Size = UDim2.new(1, 0, 0, 58)
    hdr.BackgroundColor3 = C.panel
    hdr.Parent = win
    corner(hdr, 14)
    local hfix = Instance.new("Frame")
    hfix.Size = UDim2.new(1, 0, 0, 18)
    hfix.Position = UDim2.new(0, 0, 1, -18)
    hfix.BackgroundColor3 = C.panel
    hfix.BorderSizePixel = 0
    hfix.Parent = hdr

    local tl = Instance.new("TextLabel")
    tl.Text = title
    tl.TextSize = 16
    tl.Font = Enum.Font.GothamBold
    tl.TextColor3 = C.accent
    tl.BackgroundTransparency = 1
    tl.Size = UDim2.new(1, -52, 0, 24)
    tl.Position = UDim2.new(0, 14, 0, 7)
    tl.TextXAlignment = Enum.TextXAlignment.Left
    tl.Parent = hdr

    if subtitle then
        local sl = Instance.new("TextLabel")
        sl.Text = subtitle
        sl.TextSize = 10
        sl.Font = Enum.Font.Gotham
        sl.TextColor3 = C.muted
        sl.BackgroundTransparency = 1
        sl.Size = UDim2.new(1, -52, 0, 14)
        sl.Position = UDim2.new(0, 14, 0, 34)
        sl.TextXAlignment = Enum.TextXAlignment.Left
        sl.Parent = hdr
    end

    -- FIX #5 / #7: Always create close button; onClose always destroys sg
    local cb = Instance.new("TextButton")
    cb.Text = "✕"
    cb.TextSize = 15
    cb.Font = Enum.Font.GothamBold
    cb.TextColor3 = C.muted
    cb.BackgroundTransparency = 1
    cb.Size = UDim2.new(0, 34, 0, 34)
    cb.Position = UDim2.new(1, -40, 0, 12)
    cb.Parent = hdr
    cb.MouseButton1Click:Connect(function()
        TweenService:Create(win, TweenInfo.new(0.15),
            {BackgroundTransparency = 1}):Play()
        task.delay(0.18, function()
            sg:Destroy()  -- always destroy the ScreenGui
        end)
        if onClose then onClose() end
    end)

    -- drag
    local drag, ds, sp = false, nil, nil
    hdr.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            drag = true; ds = i.Position; sp = win.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
            local d = i.Position - ds
            win.Position = UDim2.new(sp.X.Scale, sp.X.Offset+d.X, sp.Y.Scale, sp.Y.Offset+d.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
    end)

    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.new(1, 0, 1, -62)
    scroll.Position = UDim2.new(0, 0, 0, 62)
    scroll.BackgroundTransparency = 1
    scroll.ScrollBarThickness = 3
    scroll.ScrollBarImageColor3 = C.accent
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    scroll.Parent = win

    local body = Instance.new("Frame")
    body.Size = UDim2.new(1, 0, 0, 0)
    body.BackgroundTransparency = 1
    body.AutomaticSize = Enum.AutomaticSize.Y
    body.Parent = scroll
    pad(body, 14, 10)
    vlist(body, 10)

    return win, body
end


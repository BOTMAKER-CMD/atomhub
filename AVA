    logo.Parent = inner

    lbl(inner, "AVA — Atom Vanguard Array", 20, C.text, true, Enum.TextXAlignment.Center, 2)
    lbl(inner, "Enter your Discord ID and panel password.", 12, C.muted, false, Enum.TextXAlignment.Center, 3)

    divider(inner, 4)

    -- Discord ID field
    lbl(inner, "Discord ID", 11, C.muted, true, nil, 5)
    local idFrame = Instance.new("Frame")
    idFrame.BackgroundColor3 = C.input_bg
    idFrame.Size = UDim2.new(1, 0, 0, 46)
    idFrame.LayoutOrder = 6
    idFrame.Parent = inner
    corner(idFrame, 10)
    stroke(idFrame, C.border, 1)
    local idBox = Instance.new("TextBox")
    idBox.PlaceholderText = "e.g. 1155023196907647006"
    idBox.PlaceholderColor3 = C.muted
    idBox.TextColor3 = C.text
    idBox.Font = Enum.Font.Gotham
    idBox.TextSize = 14
    idBox.BackgroundTransparency = 1
    idBox.Size = UDim2.new(1, -16, 1, 0)
    idBox.Position = UDim2.new(0, 8, 0, 0)
    idBox.TextXAlignment = Enum.TextXAlignment.Left
    idBox.ClearTextOnFocus = false
    idBox.Parent = idFrame
    idBox.Focused:Connect(function()
        TweenService:Create(idFrame, TweenInfo.new(0.12),
            {BackgroundColor3 = Color3.fromRGB(30, 35, 48)}):Play()
        for _, s in ipairs(idFrame:GetChildren()) do
            if s:IsA("UIStroke") then s.Color = C.accent end
        end
    end)
    idBox.FocusLost:Connect(function()
        TweenService:Create(idFrame, TweenInfo.new(0.12),
            {BackgroundColor3 = C.input_bg}):Play()
        for _, s in ipairs(idFrame:GetChildren()) do
            if s:IsA("UIStroke") then s.Color = C.border end
        end
    end)

    -- Password field
    -- FIX #3 & #4: real show/hide masking using a dot-overlay label
    -- The TextBox always holds the real text (needed for submission).
    -- A covering TextLabel shows "●●●●" when masked; hidden when revealed.
    lbl(inner, "Panel Password", 11, C.muted, true, nil, 7)
    local pwFrame = Instance.new("Frame")
    pwFrame.BackgroundColor3 = C.input_bg
    pwFrame.Size = UDim2.new(1, 0, 0, 46)
    pwFrame.LayoutOrder = 8
    pwFrame.Parent = inner
    corner(pwFrame, 10)
    stroke(pwFrame, C.border, 1)

    -- Real (invisible) TextBox captures keystrokes
    local pwBox = Instance.new("TextBox")
    pwBox.PlaceholderText = "Password set via >setpanelpass"
    pwBox.PlaceholderColor3 = C.muted
    pwBox.TextColor3 = Color3.fromRGB(0, 0, 0, 0)  -- fully transparent text
    pwBox.TextTransparency = 1                        -- hide real text
    pwBox.Font = Enum.Font.Gotham
    pwBox.TextSize = 14
    pwBox.BackgroundTransparency = 1
    pwBox.Size = UDim2.new(1, -52, 1, 0)
    pwBox.Position = UDim2.new(0, 8, 0, 0)
    pwBox.TextXAlignment = Enum.TextXAlignment.Left
    pwBox.ClearTextOnFocus = false
    pwBox.ZIndex = 3
    pwBox.Parent = pwFrame

    -- Dot-mask overlay label (shown when password is hidden)
    local maskLbl = Instance.new("TextLabel")
    maskLbl.BackgroundTransparency = 1
    maskLbl.Size = UDim2.new(1, -52, 1, 0)
    maskLbl.Position = UDim2.new(0, 8, 0, 0)
    maskLbl.TextXAlignment = Enum.TextXAlignment.Left
    maskLbl.TextColor3 = C.text
    maskLbl.Font = Enum.Font.GothamBold
    maskLbl.TextSize = 18   -- slightly larger so dots look natural
    maskLbl.Text = ""
    maskLbl.ZIndex = 2
    maskLbl.Parent = pwFrame

    -- Placeholder label (shown when pwBox is empty AND masked)
    local pwPlaceholder = Instance.new("TextLabel")
    pwPlaceholder.BackgroundTransparency = 1
    pwPlaceholder.Size = UDim2.new(1, -52, 1, 0)
    pwPlaceholder.Position = UDim2.new(0, 8, 0, 0)
    pwPlaceholder.TextXAlignment = Enum.TextXAlignment.Left
    pwPlaceholder.TextColor3 = C.muted
    pwPlaceholder.Font = Enum.Font.Gotham
    pwPlaceholder.TextSize = 14
    pwPlaceholder.Text = "Password set via >setpanelpass"
    pwPlaceholder.ZIndex = 1
    pwPlaceholder.Parent = pwFrame

    local pwVisible = false

    -- Keep mask/placeholder in sync as user types
    local function syncMask()
        local raw = pwBox.Text
        if raw == "" then
            maskLbl.Text = ""
            pwPlaceholder.Visible = not pwVisible
        else
            pwPlaceholder.Visible = false
            if pwVisible then
                maskLbl.Text = raw
                maskLbl.Font = Enum.Font.Gotham
                maskLbl.TextSize = 14
                maskLbl.TextColor3 = C.text
            else
                maskLbl.Text = string.rep("●", #raw)
                maskLbl.Font = Enum.Font.GothamBold
                maskLbl.TextSize = 18
                maskLbl.TextColor3 = C.text
            end
        end
    end

    pwBox:GetPropertyChangedSignal("Text"):Connect(syncMask)

    -- Show/Hide toggle (eye button)
    local eyeBtn = Instance.new("TextButton")
    eyeBtn.Text = "👁"
    eyeBtn.TextSize = 16
    eyeBtn.Font = Enum.Font.Gotham
    eyeBtn.TextColor3 = C.muted
    eyeBtn.BackgroundTransparency = 1
    eyeBtn.Size = UDim2.new(0, 40, 1, 0)
    eyeBtn.Position = UDim2.new(1, -44, 0, 0)
    eyeBtn.ZIndex = 4
    eyeBtn.Parent = pwFrame
    eyeBtn.MouseButton1Click:Connect(function()
        pwVisible = not pwVisible
        eyeBtn.TextColor3 = pwVisible and C.accent or C.muted
        syncMask()
    end)

    pwBox.Focused:Connect(function()
        TweenService:Create(pwFrame, TweenInfo.new(0.12),
            {BackgroundColor3 = Color3.fromRGB(30, 35, 48)}):Play()
        for _, s in ipairs(pwFrame:GetChildren()) do
            if s:IsA("UIStroke") then s.Color = C.accent end
        end
    end)
    pwBox.FocusLost:Connect(function()
        TweenService:Create(pwFrame, TweenInfo.new(0.12),
            {BackgroundColor3 = C.input_bg}):Play()
        for _, s in ipairs(pwFrame:GetChildren()) do
            if s:IsA("UIStroke") then s.Color = C.border end
        end
    end)

    -- Error label
    local errLbl = Instance.new("TextLabel")
    errLbl.Text = ""
    errLbl.TextSize = 12
    errLbl.Font = Enum.Font.Gotham
    errLbl.TextColor3 = C.red
    errLbl.BackgroundTransparency = 1
    errLbl.Size = UDim2.new(1, 0, 0, 0)
    errLbl.AutomaticSize = Enum.AutomaticSize.Y
    errLbl.TextXAlignment = Enum.TextXAlignment.Center
    errLbl.TextWrapped = true
    errLbl.Visible = false
    errLbl.LayoutOrder = 9
    errLbl.Parent = inner

    local function setErr(msg)
        errLbl.Text = "⚠️  " .. msg
        errLbl.Visible = true
        TweenService:Create(errLbl, TweenInfo.new(0.1), {TextColor3 = C.red}):Play()
        local ox = card.Position
        for _, dx in ipairs({-4, 4, -3, 3, -1, 1, 0}) do
            task.wait(0.04)
            card.Position = UDim2.new(ox.X.Scale, ox.X.Offset + dx, ox.Y.Scale, ox.Y.Offset)
        end
        card.Position = ox
    end

    local function clearErr()
        errLbl.Visible = false
    end

    -- Login button
    local loginBtn = mkBtn(inner, "🔓   Log In", C.accent, C.black, function()
        local discStr  = idBox.Text:gsub("%s", "")
        local password = pwBox.Text   -- read real text from the invisible TextBox

        clearErr()

        if discStr == ""          then setErr("Please enter your Discord ID.");            return end
        if not tonumber(discStr)  then setErr("Discord ID must be a number — no letters."); return end
        if #discStr < 15          then setErr("Discord ID looks too short. Check again."); return end
        if password == ""         then setErr("Please enter your panel password.");         return end
        if #password < 4          then setErr("Password must be at least 4 characters.");   return end

        loginBtn.Text = "⏳  Logging in..."
        loginBtn.BackgroundColor3 = C.muted
        loginBtn.Active = false

        task.spawn(function()
            local data, err = POST("/auth/login", {
                discord_id = tonumber(discStr),
                password   = password,
            })

            loginBtn.Text = "🔓   Log In"
            loginBtn.BackgroundColor3 = C.accent
            loginBtn.Active = true

            if err then
                local friendly = err
                if err:find("not found") then
                    friendly = "Discord ID not found. Use >setpanelpass in Discord first."
                elseif err:find("Incorrect") or err:find("password") then
                    friendly = "Wrong password. Try again or reset with >setpanelpass."
                elseif err:find("Too many") then
                    friendly = err
                elseif err:find("outdated") then
                    friendly = "Password outdated — run >setpanelpass in Discord to reset."
                end
                setErr(friendly)
                return
            end

            State.token           = data.token
            State.primary_profile = data.primary_profile
            State.guilds          = data.guilds

            saveSession(data.token, tonumber(discStr))

            toast("✅  " .. (data.message or "Logged in!"), false)
            kill("AVA_Login")

            task.delay(0.3, function()
                if #State.guilds == 1 then
                    openMainPanel(State.guilds[1])
                else
                    openGuildSelector()
                end
            end)
        end)
    end, 10)

    lbl(inner, "Don't have a password? Use >setpanelpass in your Discord server.",
        11, C.muted, false, Enum.TextXAlignment.Center, 11)

    TweenService:Create(card,
        TweenInfo.new(0.28, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
        {Position = UDim2.new(0.5, -220, 0.5, -200), BackgroundTransparency = 0}):Play()
end

-- ════════════════════════════════════════════════════════
--  PAGE 0: INTRO VIDEO
-- ════════════════════════════════════════════════════════
local function playIntroVideo()
    kill("AVA_Intro")
    local sg = makeScreen("AVA_Intro")

    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, 0, 1, 0)
    bg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    bg.Parent = sg

    local skipLbl = Instance.new("TextLabel")
    skipLbl.Text = "Press [ESC] to skip intro"
    skipLbl.TextSize = 11
    skipLbl.Font = Enum.Font.Gotham
    skipLbl.TextColor3 = C.muted
    skipLbl.BackgroundTransparency = 1
    skipLbl.Size = UDim2.new(0, 200, 0, 22)
    skipLbl.Position = UDim2.new(1, -208, 1, -30)
    skipLbl.TextXAlignment = Enum.TextXAlignment.Right
    skipLbl.Parent = sg

    local played = false
    local function afterVideo()
        if played then return end
        played = true
        TweenService:Create(bg, TweenInfo.new(0.4), {BackgroundTransparency = 1}):Play()
        task.delay(0.45, function()
            kill("AVA_Intro")
            openLoginPage()
        end)
    end

    local vf = Instance.new("VideoFrame")
    vf.Size = UDim2.new(1, 0, 1, 0)
    vf.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    vf.Video = INTRO_VIDEO_ID
    vf.Looped = false
    vf.Volume = 0.8
    vf.Parent = sg
    vf.Ended:Connect(afterVideo)

    -- FIX #2: call Play() directly — VideoFrame loads and plays without IsLoaded guard
    task.spawn(function()
        task.wait(0.5)
        vf:Play()
    end)

    -- FIX #1: fallback timer raised from 3s to 15s to allow video time to load
    task.delay(15, function() if not played then afterVideo() end end)
    -- Absolute max cap (unchanged)
    task.delay(60, afterVideo)

    local conn
    conn = UserInputService.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == Enum.KeyCode.Escape then
            conn:Disconnect()
            afterVideo()
        end
    end)
end

-- ════════════════════════════════════════════════════════
--  ENTRY POINT
-- ════════════════════════════════════════════════════════
if pgui:FindFirstChild("AVA_Running") then
    toast("AVA panel is already open.", false)
    return
end

-- FIX #8: track the flag so close handlers can destroy it
local flag = Instance.new("BoolValue")
flag.Name = "AVA_Running"
flag.Parent = pgui
-- Clean up on character removal (respawn) automatically
game:GetService("Players").LocalPlayer.CharacterRemoving:Connect(function()
    flag:Destroy()
end)

-- Try to restore session from attributes (survives respawn)
local savedToken, savedDiscId = loadSession()
if savedToken then
    State.token = savedToken
    task.spawn(function()
        local data, err = GET("/auth/me")
        if err then
            clearSession()
            playIntroVideo()
        else
            State.primary_profile = data.primary_profile
            State.guilds          = data.guilds
            toast("✅  Session restored — welcome back!", false)
            if #State.guilds == 1 then
                openMainPanel(State.guilds[1])
            else
                openGuildSelector()
            end
        end
    end)
else
    playIntroVideo()
end

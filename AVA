--  CROSS-SERVER ASSIGN PANEL  (Admin+)
-- ════════════════════════════════════════════════════════
local function openAssignPanel(otp, homeGuildId, onDone)
    local sg = makeScreen("AVA_AssignPanel")
    -- FIX #7: onClose now destroys sg via scrollWindow's built-in close handler
    local _, body = scrollWindow(sg, 480, 560,
        "🌐  Assign Task — " .. otp,
        "Select a staff member from any server",
        function()
            kill("AVA_AssignPanel")
        end)

    local spin  = skeleton(body, 24, 1)
    local spin2 = skeleton(body, 60, 2)

    task.spawn(function()
        local data, err = GET("/panel/" .. homeGuildId .. "/crossstaff")
        spin:Destroy()
        spin2:Destroy()

        if err then
            lbl(body, "❌  " .. err, 12, C.red, false, nil, 1)
            return
        end

        local totalStaff = data.total_staff or 0
        lbl(body, totalStaff .. " staff across " .. #data.guilds .. " server(s)", 11, C.muted, false, nil, 1)

        local lo = 10
        for _, guild in ipairs(data.guilds) do
            secHead(body, "📡  " .. (guild.server_name or guild.guild_name or "Unknown"), C.accent, lo)
            lo = lo + 1

            for _, staff in ipairs(guild.staff) do
                local card = Instance.new("TextButton")
                card.BackgroundColor3 = C.card
                card.Size = UDim2.new(1, 0, 0, 0)
                card.AutomaticSize = Enum.AutomaticSize.Y
                card.LayoutOrder = lo
                card.Text = ""
                card.AutoButtonColor = false
                corner(card, 8)
                card.Parent = body
                pad(card, 12, 8)

                local row = Instance.new("Frame")
                row.BackgroundTransparency = 1
                row.Size = UDim2.new(1, 0, 0, 0)
                row.AutomaticSize = Enum.AutomaticSize.Y
                row.Parent = card

                local dc = DESIG_C[staff.designation] or C.blue
                lbl(row, staff.display_name or staff.roblox_username, 14, C.text, true)
                lbl(row, staff.designation, 10, dc)
                lbl(row, "@" .. staff.roblox_username, 10, C.muted)

                card.MouseEnter:Connect(function()
                    TweenService:Create(card, TweenInfo.new(0.1),
                        {BackgroundColor3 = Color3.fromRGB(30, 35, 46)}):Play()
                end)
                card.MouseLeave:Connect(function()
                    TweenService:Create(card, TweenInfo.new(0.1),
                        {BackgroundColor3 = C.card}):Play()
                end)

                local capturedStaff = staff
                local capturedGuild = guild
                card.MouseButton1Click:Connect(function()
                    card.BackgroundColor3 = C.accent
                    task.spawn(function()
                        local r, e = POST("/panel/" .. homeGuildId .. "/assign", {
                            otp               = otp,
                            target_discord_id = capturedStaff.discord_id,
                            target_guild_id   = capturedGuild.guild_id,
                        })
                        if e then
                            toast("❌  " .. e, true)
                            card.BackgroundColor3 = C.card
                        else
                            toast("✅  Assigned to " .. (capturedStaff.display_name or "staff"), false)
                            sg:Destroy()
                            if onDone then onDone() end
                        end
                    end)
                end)

                lo = lo + 1
            end
        end
    end)
end


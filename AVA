local State = {
    token           = nil,
    primary_profile = nil,
    guilds          = {},
    active_guild    = nil,
    panel_data      = nil,
}

-- Session persistence keys stored as PlayerGui attributes
local ATTR_TOKEN   = "AVA_SessionToken"
local ATTR_DISCORD = "AVA_DiscordId"

local function saveSession(token, discordId)
    pcall(function()
        pgui:SetAttribute(ATTR_TOKEN,   token or "")
        pgui:SetAttribute(ATTR_DISCORD, tostring(discordId or ""))
    end)
end

local function loadSession()
    local ok,  token  = pcall(function() return pgui:GetAttribute(ATTR_TOKEN)   end)
    local ok2, discId = pcall(function() return pgui:GetAttribute(ATTR_DISCORD) end)
    if ok and ok2 and token and token ~= "" then
        return token, tonumber(discId)
    end
    return nil, nil
end

local function clearSession()
    saveSession("", "")
    State.token           = nil
    State.primary_profile = nil
    State.guilds          = {}
    State.active_guild    = nil
    State.panel_data      = nil
end

-- ════════════════════════════════════════════════════════
--  HTTP  (with retry)
-- ════════════════════════════════════════════════════════
local MAX_RETRIES  = 3
local RETRY_DELAYS = {1, 2, 4}

local function apiCall(method, path, body, skipKey)
    local headers = { ["Content-Type"] = "application/json" }
    if not skipKey then
        headers["x-api-key"] = PANEL_API_KEY
    end
    if State.token then
        headers["x-session-token"] = State.token
    end

    local attempt = 0
    while attempt < MAX_RETRIES do
        attempt = attempt + 1
        local ok, res = pcall(HttpService.RequestAsync, HttpService, {
            Url     = API_URL .. path,
            Method  = method,
            Headers = headers,
            Body    = body and HttpService:JSONEncode(body) or nil,
        })

        if not ok then
            if attempt < MAX_RETRIES then
                task.wait(RETRY_DELAYS[attempt])
                continue
            end
            return nil, "Network error — check your connection. (tried " .. MAX_RETRIES .. "x)"
        end

        local decode_ok, data = pcall(HttpService.JSONDecode, HttpService, res.Body)
        if not decode_ok then
            return nil, "Server returned invalid response."
        end

        if res.StatusCode == 401 then
            clearSession()
            return nil, data.detail or "Session expired. Please log in again."
        end
        if res.StatusCode == 429 then
            return nil, data.detail or "Too many attempts. Please wait before trying again."
        end
        if res.StatusCode == 403 then return nil, data.detail or "Access denied."    end
        if res.StatusCode == 404 then return nil, data.detail or "Not found."        end
        if res.StatusCode == 400 then return nil, data.detail or "Invalid request."  end

        if res.StatusCode >= 500 then
            if attempt < MAX_RETRIES then
                task.wait(RETRY_DELAYS[attempt])
                continue
            end
            return nil, data.detail or ("Server error " .. res.StatusCode .. " after " .. MAX_RETRIES .. " tries.")
        end

        if res.StatusCode ~= 200 and res.StatusCode ~= 201 then
            return nil, data.detail or ("Unexpected status " .. res.StatusCode)
        end

        return data, nil
    end
    return nil, "Request failed after all retries."
end

local function GET(path)     return apiCall("GET",  path, nil) end
local function POST(path, b) return apiCall("POST", path, b)   end
local function DEL(path)     return apiCall("DELETE", path, nil) end

-- ════════════════════════════════════════════════════════
--  UI PRIMITIVES
-- ════════════════════════════════════════════════════════
local function kill(name)
    local e = pgui:FindFirstChild(name)
    if e then e:Destroy() end
end

local function corner(p, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 8)
    c.Parent = p
    return c
end

local function stroke(p, col, t)
    local s = Instance.new("UIStroke")
    s.Color = col or C.accent
    s.Thickness = t or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = p
    return s
end

local function pad(p, px, py)
    local u = Instance.new("UIPadding")
    u.PaddingTop    = UDim.new(0, py or px)
    u.PaddingBottom = UDim.new(0, py or px)
    u.PaddingLeft   = UDim.new(0, px)
    u.PaddingRight  = UDim.new(0, px)
    u.Parent = p
end

local function vlist(p, gap)
    local l = Instance.new("UIListLayout")
    l.SortOrder = Enum.SortOrder.LayoutOrder
    l.Padding = UDim.new(0, gap or 8)
    l.Parent = p
    return l
end

local function hlist(p, gap)
    local l = Instance.new("UIListLayout")
    l.SortOrder = Enum.SortOrder.LayoutOrder
    l.FillDirection = Enum.FillDirection.Horizontal
    l.Padding = UDim.new(0, gap or 8)
    l.Parent = p
    return l
end

local function lbl(parent, text, size, color, bold, xa, lo)
    local l = Instance.new("TextLabel")
    l.Text = text or ""
    l.TextSize = size or 14
    l.TextColor3 = color or C.text
    l.Font = bold and Enum.Font.GothamBold or Enum.Font.Gotham
    l.BackgroundTransparency = 1
    l.TextWrapped = true
    l.AutomaticSize = Enum.AutomaticSize.Y
    l.Size = UDim2.new(1, 0, 0, 0)
    l.TextXAlignment = xa or Enum.TextXAlignment.Left
    if lo then l.LayoutOrder = lo end
    l.Parent = parent
    return l
end

local function divider(parent, lo)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1, 0, 0, 1)
    f.BackgroundColor3 = C.border
    f.BorderSizePixel = 0
    if lo then f.LayoutOrder = lo end
    f.Parent = parent
    return f
end

local function skeleton(parent, h, lo)
    local f = Instance.new("Frame")
    f.BackgroundColor3 = C.skeleton
    f.Size = UDim2.new(1, 0, 0, h or 20)
    if lo then f.LayoutOrder = lo end
    f.Parent = parent
    corner(f, 6)
    local shimmer = Instance.new("Frame")
    shimmer.BackgroundColor3 = Color3.fromRGB(40, 46, 60)
    shimmer.Size = UDim2.new(0.3, 0, 1, 0)
    shimmer.Position = UDim2.new(-0.3, 0, 0, 0)
    shimmer.BorderSizePixel = 0
    shimmer.Parent = f
    TweenService:Create(shimmer, TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1),
        {Position = UDim2.new(1, 0, 0, 0)}):Play()
    return f
end

-- ════════════════════════════════════════════════════════
--  BUTTONS
-- ════════════════════════════════════════════════════════
local function mkBtn(parent, text, bg, tc, cb, lo, h)
    local b = Instance.new("TextButton")
    b.Text = text
    b.TextSize = 13
    b.Font = Enum.Font.GothamBold
    b.TextColor3 = tc or C.black
    b.BackgroundColor3 = bg or C.accent
    b.AutoButtonColor = false
    b.Size = UDim2.new(1, 0, 0, h or 40)
    if lo then b.LayoutOrder = lo end
    b.Parent = parent
    corner(b, 8)

    b.MouseEnter:Connect(function()
        TweenService:Create(b, TweenInfo.new(0.1),
            {BackgroundColor3 = (bg or C.accent):Lerp(C.white, 0.12)}):Play()
    end)
    b.MouseLeave:Connect(function()
        TweenService:Create(b, TweenInfo.new(0.1), {BackgroundColor3 = bg or C.accent}):Play()
    end)
    b.MouseButton1Click:Connect(cb)
    return b
end

local function mkSmallBtn(parent, text, bg, tc, cb, lo)
    return mkBtn(parent, text, bg, tc, cb, lo, 30)
end


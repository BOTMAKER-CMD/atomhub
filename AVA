-- STAFF PANEL (/ava)
-- ═══════════════════════════════════════════════════════
local function openStaffPanel()
    local _, _, body = createWindow("AVA_StaffPanel", 520, 660)
    lbl(body, "⏳ Checking staff permissions...", 13, C.muted, false, Enum.TextXAlignment.Center).LayoutOrder = 1

    task.spawn(function()
        local data, err = apiGet("/staff/me?roblox_username=" .. HttpService:UrlEncode(robloxName))

        -- Clear loader
        for _, c in ipairs(body:GetChildren()) do
            if c:IsA("TextLabel") then c:Destroy() end
        end

        if err then
            lbl(body, "❌ " .. err, 13, C.red, false, Enum.TextXAlignment.Center).LayoutOrder = 1
            return
        end

        if not data.registered or not data.is_staff then
            notRegisteredCard(body, data.message or "You are not registered as AVA staff.", 1)
            return
        end

        local P = data.profile
        local S = data.summary
        local T = data.tasks or {pending = {}, started = {}, finished = {}}

        identityHeader(body, P, 1)
        sectionHead(body, "📊 YOUR TASKS", C.muted, 3)
        statRow(body, S, 4)

        local lo = 10

        if #T.pending > 0 then
            sectionHead(body, "⏳ PENDING (" .. #T.pending .. ")", C.yellow, lo); lo += 1
            for _, t in ipairs(T.pending) do
                taskRow(body, t, lo, function(otp)
                    toast("⏳ Completing " .. otp .. "...", false)
                    task.spawn(function()
                        local r, e = apiPost("/complete", {
                            otp = otp,
                            roblox_username = robloxName
                        })
                        if e then toast("❌ " .. e, true)
                        elseif not r.success then toast("⚠️ " .. (r.message or "Error"), true)
                        else toast("✅ " .. otp .. " completed!", false); task.delay(0.6, openStaffPanel) end
                    end)
                end)
                lo += 1
            end
        end

        if #T.started > 0 then
            sectionHead(body, "▶️ IN PROGRESS (" .. #T.started .. ")", C.blue, lo); lo += 1
            for _, t in ipairs(T.started) do
                taskRow(body, t, lo, function(otp)
                    toast("⏳ Completing " .. otp .. "...", false)
                    task.spawn(function()
                        local r, e = apiPost("/complete", {
                            otp = otp,
                            roblox_username = robloxName
                        })
                        if e then toast("❌ " .. e, true)
                        elseif not r.success then toast("⚠️ " .. (r.message or "Error"), true)
                        else toast("✅ " .. otp .. " completed!", false); task.delay(0.6, openStaffPanel) end
                    end)
                end)
                lo += 1
            end
        end

        if #T.finished > 0 then
            sectionHead(body, "✅ RECENTLY FINISHED", C.accent, lo); lo += 1
            for _, t in ipairs(T.finished) do
                taskRow(body, t, lo, function() end)
                lo += 1
            end
        end

        if S.total == 0 then
            lbl(body, "🎉 No tasks assigned to you right now.", 14, C.muted, false, Enum.TextXAlignment.Center).LayoutOrder = lo
        end

        local rb = btn(body, "🔄 Refresh Panel", C.cardAlt, C.accent, openStaffPanel)
        rb.LayoutOrder = 999; stroke(rb, C.accent, 1)
    end)
end


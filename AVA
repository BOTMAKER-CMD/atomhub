--  TOAST
-- ════════════════════════════════════════════════════════
local function toast(msg, isErr, duration)
    kill("AVA_Toast")
    local sg = Instance.new("ScreenGui")
    sg.Name = "AVA_Toast"
    sg.ResetOnSpawn = false
    sg.ZIndexBehavior = Enum.ZIndexBehavior.Global
    sg.Parent = pgui

    local f = Instance.new("Frame")
    f.Size = UDim2.new(0, 420, 0, 50)
    f.Position = UDim2.new(0.5, -210, 1, 10)
    f.BackgroundColor3 = isErr and C.red or C.accent
    f.Parent = sg
    corner(f, 10)

    local l = Instance.new("TextLabel")
    l.Text = "  " .. msg
    l.TextSize = 13
    l.Font = Enum.Font.GothamBold
    l.TextColor3 = C.black
    l.BackgroundTransparency = 1
    l.Size = UDim2.new(1, -10, 1, 0)
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.TextWrapped = true
    l.Parent = f

    TweenService:Create(f, TweenInfo.new(0.25, Enum.EasingStyle.Quart),
        {Position = UDim2.new(0.5, -210, 1, -65)}):Play()
    task.delay(duration or 3.5, function()
        TweenService:Create(f, TweenInfo.new(0.2),
            {Position = UDim2.new(0.5, -210, 1, 10)}):Play()
        task.delay(0.25, function() sg:Destroy() end)
    end)
end


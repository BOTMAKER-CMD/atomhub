-- HTTP HELPERS
-- ═══════════════════════════════════════════════════════
local function apiGet(path)
    local ok, res = pcall(HttpService.RequestAsync, HttpService, {
        Url = API_URL .. path,
        Method = "GET",
        Headers = { ["Content-Type"] = "application/json", ["x-api-key"] = API_KEY },
    })
    if not ok then return nil, "Network error — check API_URL." end
    if res.StatusCode == 403 then return nil, "Invalid API key or unauthorized." end
    if res.StatusCode == 404 then return nil, "Not found." end
    if res.StatusCode ~= 200 then return nil, "API error " .. res.StatusCode end

    local d, e = pcall(HttpService.JSONDecode, HttpService, res.Body)
    if not d then return nil, "JSON parse error." end
    return d, nil
end

local function apiPost(path, body)
    local ok, res = pcall(HttpService.RequestAsync, HttpService, {
        Url = API_URL .. path,
        Method = "POST",
        Headers = { ["Content-Type"] = "application/json", ["x-api-key"] = API_KEY },
        Body = HttpService:JSONEncode(body),
    })
    if not ok then return nil, "Network error." end
    if res.StatusCode == 403 then return nil, "Permission denied." end
    if res.StatusCode == 404 then return nil, "Not found." end
    if res.StatusCode ~= 200 then return nil, "API error " .. res.StatusCode end

    local d, e = pcall(HttpService.JSONDecode, HttpService, res.Body)
    if not d then return nil, "JSON parse error." end
    return d, nil
end


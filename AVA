    lbl(inner, svc.name, 14, C.text, true, nil, 2)
    lbl(inner, "💎  " .. svc.value .. "    👤  " .. (svc.roblox_username ~= "" and "@" .. svc.roblox_username or "—"), 12, C.muted, false, nil, 3)
    lbl(inner, STATUS_I[svc.status] or svc.status:upper(), 12, STATUS_C[svc.status] or C.muted, false, nil, 4)

    -- FIX #10: inline svc.source_guild_name directly, removed unused local
    if svc.source_guild_name and svc.source_guild_name ~= "" then
        lbl(inner, "🌐  From: " .. svc.source_guild_name, 10, C.purple, false, nil, 5)
    end

    if svc.due_date then
        lbl(inner, "📅  Due: " .. svc.due_date:sub(1, 10), 10, C.orange, false, nil, 6)
    end

    if svc.tags and #svc.tags > 0 then
        local tagStr = table.concat(svc.tags, "  #")
        lbl(inner, "#" .. tagStr, 10, C.muted, false, nil, 7)
    end

    if svc.notes and #svc.notes > 0 then
        local latest = svc.notes[#svc.notes]
        local noteFrame = Instance.new("Frame")
        noteFrame.BackgroundColor3 = C.cardAlt
        noteFrame.Size = UDim2.new(1, 0, 0, 0)
        noteFrame.AutomaticSize = Enum.AutomaticSize.Y
        noteFrame.LayoutOrder = 8
        noteFrame.Parent = inner
        corner(noteFrame, 6)
        pad(noteFrame, 8, 6)
        stroke(noteFrame, C.border, 1)
        lbl(noteFrame, "📝  " .. latest.note, 11, C.muted)
        if #svc.notes > 1 then
            lbl(noteFrame, "+" .. (#svc.notes - 1) .. " more note(s)", 10, C.muted)
        end
    end

    if svc.status == "pending" or svc.status == "started" then
        local btnRow = Instance.new("Frame")
        btnRow.BackgroundTransparency = 1
        btnRow.Size = UDim2.new(1, 0, 0, 36)
        btnRow.LayoutOrder = 9
        btnRow.Parent = inner
        hlist(btnRow, 8)

        if svc.status == "pending" then
            local startBtn = Instance.new("TextButton")
            startBtn.Text = "▶  Start"
            startBtn.TextSize = 12
            startBtn.Font = Enum.Font.GothamBold
            startBtn.TextColor3 = C.black
            startBtn.BackgroundColor3 = C.blue
            startBtn.AutoButtonColor = false
            startBtn.Size = UDim2.new(0.48, 0, 1, 0)
            corner(startBtn, 7)
            startBtn.Parent = btnRow
            startBtn.MouseButton1Click:Connect(function()
                startBtn.Text = "⏳"
                startBtn.Active = false
                onAction("start", svc.otp, guild_id)
            end)
        end

        local doneBtn = Instance.new("TextButton")
        doneBtn.Text = "✅  Complete"
        doneBtn.TextSize = 12
        doneBtn.Font = Enum.Font.GothamBold
        doneBtn.TextColor3 = C.black
        doneBtn.BackgroundColor3 = C.accent
        doneBtn.AutoButtonColor = false
        doneBtn.Size = svc.status == "pending" and UDim2.new(0.48, 0, 1, 0) or UDim2.new(1, 0, 1, 0)
        corner(doneBtn, 7)
        doneBtn.Parent = btnRow
        doneBtn.MouseButton1Click:Connect(function()
            doneBtn.Text = "⏳"
            doneBtn.Active = false
            onAction("complete", svc.otp, guild_id)
        end)
    end
end


-- CLIENT PANEL (/order)
-- ═══════════════════════════════════════════════════════
local function openOrderPanel()
    local _, _, body = createWindow("AVA_OrderPanel", 470, 580)
    lbl(body, "⏳ Looking up your orders...", 13, C.muted, false, Enum.TextXAlignment.Center).LayoutOrder = 1

    task.spawn(function()
        local data, err = apiGet("/order/me?roblox_username=" .. HttpService:UrlEncode(robloxName))

        for _, c in ipairs(body:GetChildren()) do
            if c:IsA("TextLabel") then c:Destroy() end
        end

        if err then
            lbl(body, "❌ " .. err, 13, C.red, false, Enum.TextXAlignment.Center).LayoutOrder = 1
            return
        end

        if not data.registered then
            notRegisteredCard(body, data.message or "Account not found.", 1)
            return
        end

        local P = data.profile
        identityHeader(body, P, 1)
        sectionHead(body, "📦 YOUR ORDERS", C.muted, 3)

        local srow = Instance.new("Frame"); srow.BackgroundTransparency = 1
        srow.Size = UDim2.new(1,0,0,72); srow.LayoutOrder = 4; srow.Parent = body; hlist(srow,8)

        local function osc(val, label, col)
            local c = Instance.new("Frame"); c.BackgroundColor3 = C.card
            c.Size = UDim2.new(0.48,0,1,0); corner(c,10); stroke(c,col,1); c.Parent = srow
            local vl = Instance.new("TextLabel"); vl.Text = tostring(val or 0); vl.TextSize = 24
            vl.Font = Enum.Font.GothamBold; vl.TextColor3 = col; vl.BackgroundTransparency = 1
            vl.Size = UDim2.new(1,0,0,35); vl.Position = UDim2.new(0,0,0,6); vl.TextXAlignment = Enum.TextXAlignment.Center; vl.Parent = c
            local nl = Instance.new("TextLabel"); nl.Text = label; nl.TextSize = 10
            nl.Font = Enum.Font.Gotham; nl.TextColor3 = C.muted; nl.BackgroundTransparency = 1
            nl.Size = UDim2.new(1,0,0,16); nl.Position = UDim2.new(0,0,0,42); nl.TextXAlignment = Enum.TextXAlignment.Center; nl.Parent = c
        end

        osc(data.total_active or 0, "ACTIVE", C.yellow)
        osc(data.total_finished or 0, "COMPLETED", C.accent)

        if # (data.active_services or {}) > 0 then
            sectionHead(body, "🛒 ACTIVE SERVICES", C.yellow, 10)
            for i, svc in ipairs(data.active_services) do
                orderRow(body, svc, 10 + i)
            end
        else
            lbl(body, "✅ No active orders right now!", 14, C.muted, false, Enum.TextXAlignment.Center).LayoutOrder = 11
        end
    end)
end


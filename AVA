--  PAGE 3: MAIN PANEL
-- ════════════════════════════════════════════════════════
local function openMainPanel(guild)
    kill("AVA_MainPanel")
    State.active_guild = guild

    local sg = makeScreen("AVA_MainPanel")
    local cfg_name = guild.server_name or guild.guild_name or "AVA Services"
    -- FIX #8: onClose cleans up AVA_Running so panel can be reopened
    local _, body = scrollWindow(sg, 540, 670,
        "🛡️  " .. cfg_name,
        (guild.designation or "Staff") .. " Panel",
        function()
            State.active_guild = nil
            kill("AVA_Running")
        end)

    local sk1 = skeleton(body, 80, 1)
    local sk2 = skeleton(body, 24, 2)
    local sk3 = skeleton(body, 70, 3)
    local sk4 = skeleton(body, 70, 4)

    task.spawn(function()
        local data, err = GET("/panel/" .. guild.guild_id)
        sk1:Destroy(); sk2:Destroy(); sk3:Destroy(); sk4:Destroy()

        if err then
            local ef = Instance.new("Frame")
            ef.BackgroundColor3 = Color3.fromRGB(40, 14, 14)
            ef.Size = UDim2.new(1, 0, 0, 0)
            ef.AutomaticSize = Enum.AutomaticSize.Y
            ef.LayoutOrder = 1
            ef.Parent = body
            corner(ef, 8)
            pad(ef, 12)
            stroke(ef, C.red, 1)
            lbl(ef, "⚠️  " .. err, 13, C.red, false, Enum.TextXAlignment.Center)
            mkSmallBtn(body, "🔄  Retry", C.cardAlt, C.accent, function()
                openMainPanel(guild)
            end, 2)
            return
        end

        State.panel_data = data
        local P = data.profile
        local isAdmin = P.designation == "AVA Admin"
            or P.designation == "Server Owner"
            or P.designation == "Developer & Owner"

        identCard(body, P, 1)

        -- ── CLIENT VIEW ──────────────────────────────────────────
        if data.view == "client" then
            local orders = data.orders
            secHead(body, "📦  YOUR ORDERS", C.muted, 3)

            local srow = Instance.new("Frame")
            srow.BackgroundTransparency = 1
            srow.Size = UDim2.new(1, 0, 0, 72)
            srow.LayoutOrder = 4
            srow.Parent = body
            hlist(srow, 8)

            local function osc(val, lbl_t, col)
                local c = Instance.new("Frame")
                c.BackgroundColor3 = C.card
                c.Size = UDim2.new(0.48, 0, 1, 0)
                corner(c, 10)
                stroke(c, col, 1)
                c.Parent = srow
                local vl = Instance.new("TextLabel")
                vl.Text = tostring(val)
                vl.TextSize = 24
                vl.Font = Enum.Font.GothamBold
                vl.TextColor3 = col
                vl.BackgroundTransparency = 1
                vl.Size = UDim2.new(1, 0, 0, 36)
                vl.Position = UDim2.new(0, 0, 0, 6)
                vl.TextXAlignment = Enum.TextXAlignment.Center
                vl.Parent = c
                local nl = Instance.new("TextLabel")
                nl.Text = lbl_t
                nl.TextSize = 9
                nl.Font = Enum.Font.GothamBold
                nl.TextColor3 = C.muted
                nl.BackgroundTransparency = 1
                nl.Size = UDim2.new(1, 0, 0, 14)
                nl.Position = UDim2.new(0, 0, 0, 44)
                nl.TextXAlignment = Enum.TextXAlignment.Center
                nl.Parent = c
            end
            osc(orders.total_active   or 0, "ACTIVE",    C.yellow)
            osc(orders.total_finished or 0, "COMPLETED", C.accent)

            if orders.active and #orders.active > 0 then
                secHead(body, "🛒  ACTIVE SERVICES", C.yellow, 10)
                for i, svc in ipairs(orders.active) do
                    orderCard(body, svc, 10 + i)
                end
            else
                lbl(body, "✅  No active orders right now.", 14, C.muted, false, Enum.TextXAlignment.Center, 11)
            end

        -- ── STAFF VIEW ───────────────────────────────────────────
        else
            local S = data.summary
            local T = data.tasks

            secHead(body, "📊  YOUR TASKS", C.muted, 3)
            statRow(body, S, 4)

            local lo = 10

            local function handleAction(action, otp, gid)
                local path = "/panel/" .. gid .. "/" .. action
                task.spawn(function()
                    local r, e = POST(path, {otp = otp})
                    if e then
                        toast("❌  " .. e, true)
                    elseif r and not r.success then
                        toast("⚠️  " .. (r.message or "Error"), true)
                    else
                        toast("✅  " .. otp .. " " .. action .. "d!", false)
                        task.delay(0.4, function() openMainPanel(guild) end)
                    end
                end)
            end

            if T.pending and #T.pending > 0 then
                secHead(body, "⏳  PENDING  (" .. #T.pending .. ")", C.yellow, lo); lo = lo + 1
                for _, t in ipairs(T.pending) do
                    taskCard(body, t, lo, handleAction, guild.guild_id, isAdmin)
                    lo = lo + 1
                    if isAdmin then
                        local capturedOTP = t.otp
                        mkSmallBtn(body, "🌐  Assign Cross-Server", C.cardAlt, C.purple,
                            function()
                                openAssignPanel(capturedOTP, guild.guild_id, function()
                                    openMainPanel(guild)
                                end)
                            end, lo)
                        lo = lo + 1
                    end
                end
            end

            if T.started and #T.started > 0 then
                secHead(body, "▶️  IN PROGRESS  (" .. #T.started .. ")", C.blue, lo); lo = lo + 1
                for _, t in ipairs(T.started) do
                    taskCard(body, t, lo, handleAction, guild.guild_id, isAdmin)
                    lo = lo + 1
                end
            end

            if T.finished and #T.finished > 0 then
                secHead(body, "✅  RECENTLY FINISHED", C.accent, lo); lo = lo + 1
                for _, t in ipairs(T.finished) do
                    taskCard(body, t, lo, function() end, guild.guild_id, false)
                    lo = lo + 1
                end
            end

            if S.total == 0 then
                lbl(body, "🎉  No tasks assigned to you.", 14, C.muted, false, Enum.TextXAlignment.Center, lo)
                lo = lo + 1
            end

            -- FIX #6: store the button reference, apply stroke directly to it
            local refreshBtn = mkBtn(body, "🔄   Refresh", C.cardAlt, C.accent,
                function() openMainPanel(guild) end, 997)
            stroke(refreshBtn, C.accent, 1)
        end

        -- Logout button
        mkBtn(body, "🚪   Log Out", C.cardAlt, C.red, function()
            task.spawn(function() POST("/auth/logout", {}) end)
            clearSession()
            kill("AVA_MainPanel")
            kill("AVA_Running")  -- FIX #8: also clean up flag on logout
            toast("Logged out of AVA.", false)
        end, 1000)
    end)
end

